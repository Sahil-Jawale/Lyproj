# MedScript Environment Variables
# Copy to .env and fill in your values

# Backend
DATABASE_URL=sqlite:///./medscript.db
# DATABASE_URL=postgresql://medscript_user:your_password@localhost:5432/medscript_db
SECRET_KEY=your-secret-key-change-in-production
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
ML_SERVER_URL=http://localhost:8001

# Frontend
VITE_API_URL=http://localhost:8000

# ML
MODEL_PATH=./ml_pipeline/checkpoints/trocr_bd_prescription/best_model
DEVICE=auto

# AWS (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
